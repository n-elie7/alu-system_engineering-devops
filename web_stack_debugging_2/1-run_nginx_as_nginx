#!/usr/bin/env bash
# Configure nginx to run as nginx user on port 8080

NGINX_BIN="/usr/sbin/nginx"
NGINX_CONF="/etc/nginx/nginx.conf"
NGINX_USER="nginx"

# Ensure nginx user exists
id "$NGINX_USER" &>/dev/null || useradd -r -s /sbin/nologin "$NGINX_USER"

# Fix nginx main config: enforce user
sed -i "s/^user .*/user $NGINX_USER;/" "$NGINX_CONF"

# Ensure it listens on all interfaces on 8080
if [ -f /etc/nginx/sites-available/default ]; then
    sed -i 's/listen 80;/listen 0.0.0.0:8080;/g' /etc/nginx/sites-available/default
    sed -i 's/listen \[::\]:80;/listen [::]:8080;/g' /etc/nginx/sites-available/default
fi

# Fix permissions (critical for non-root execution)
mkdir -p /var/log/nginx /var/lib/nginx /run
chown -R "$NGINX_USER:$NGINX_USER" /var/log/nginx /var/lib/nginx /run

# Stop any running nginx
pkill nginx 2>/dev/null
sleep 1

# Run nginx completely as nginx user (NOT root)
su -s /bin/sh -c "$NGINX_BIN -c $NGINX_CONF" "$NGINX_USER"

# Verify nginx is running as nginx user
pgrep -u nginx -a nginx
