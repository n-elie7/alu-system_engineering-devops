#!/usr/bin/env bash

# Ensure user exists and update configs
id -u nginx >/dev/null 2>&1 || useradd nginx
sed -i 's/80;/8080;/g' /etc/nginx/sites-available/default
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf

# Fix permissions and PID location
chown -R nginx:nginx /var/lib/nginx /var/log/nginx
mkdir -p /var/run/nginx
chown -R nginx:nginx /var/run/nginx
sed -i 's|pid /run/nginx.pid;|pid /var/run/nginx/nginx.pid;|' /etc/nginx/nginx.conf

# Test and start as the nginx user
/usr/sbin/nginx -t && pkill nginx || true
su -s /bin/bash -c "/usr/sbin/nginx" nginx
