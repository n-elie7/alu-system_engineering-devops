#!/usr/bin/env bash
# This script updates an existing Nginx installation inside a running container
NGINX_BIN=${NGINX_BIN:-/usr/sbin/nginx}
NGINX_CONF=${NGINX_CONF:-/etc/nginx/nginx.conf}
DEFAULT_SITE_CANDIDATES=(
  /etc/nginx/sites-available/default
  /etc/nginx/sites-enabled/default
  /etc/nginx/conf.d/default.conf
  /etc/nginx/conf.d/default
)
LOG_DIRS=(/var/log/nginx /var/lib/nginx)
NGINX_USER=${NGINX_USER:-nginx}
NGINX_GROUP=${NGINX_GROUP:-nginx}

command_exists() {
  command -v \"$1\" >/dev/null 2>&1
}

if ! [[ -x \"$NGINX_BIN\" ]]; then
  echo \"[ERROR] nginx binary not found\"
  exit 1
fi

if ! [[ -f \"$NGINX_CONF\" ]]; then
  echo \"[ERROR] nginx config not found\"
  exit 1
fi

# Ensure PID and log paths are writable
pid_path=$(awk \'/^\\s*pid\\s+/{gsub(/;/,\"\",$2); print $2; exit}\' \"$NGINX_CONF\" || true)
pid_dir=$(dirname \"${pid_path:-/run/nginx.pid}\")
mkdir -p \"$pid_dir\"
chown -R \"$NGINX_USER\":\"$NGINX_GROUP\" \"$pid_dir\"

for d in \"${LOG_DIRS[@]}\"; do
  mkdir -p \"$d\"
  chown -R \"$NGINX_USER\":\"$NGINX_GROUP\" \"$d\"
done

# Restart Nginx
if pgrep -x nginx >/dev/null 2>&1; then
  pkill -9 nginx
fi

# Start as nginx user
if command_exists runuser; then
  runuser -u \"$NGINX_USER\" -- \"$NGINX_BIN\" -c \"$NGINX_CONF\"
else
  su -s /bin/sh -c \"$NGINX_BIN -c $NGINX_CONF\" \"$NGINX_USER\"
fi

if pgrep -u \"$NGINX_USER\" nginx >/dev/null; then
  echo \"Success: Nginx is running as $NGINX_USER\"
else
  echo \"Failed to start Nginx as $NGINX_USER\"
fi
