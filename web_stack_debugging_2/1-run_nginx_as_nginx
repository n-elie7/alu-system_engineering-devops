#!/usr/bin/env bash
# Fix Nginx to run as nginx user and listen on port 8080

# Ensure nginx user exists
id nginx &>/dev/null || useradd -r -s /sbin/nologin nginx

# Change user from www-data to nginx
sed -i 's/^user www-data;/user nginx;/' /etc/nginx/nginx.conf

# Change listen port from 80 to 8080
sed -i 's/listen 80 default_server;/listen 8080 default_server;/g' /etc/nginx/sites-enabled/default
sed -i 's/listen \[::\]:80 default_server;/listen [::]:8080 default_server;/g' /etc/nginx/sites-enabled/default

# Restart nginx
service nginx restart || (nginx -s stop 2>/dev/null; nginx)
